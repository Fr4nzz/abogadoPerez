---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { services } from '../data/services';
import { siteConfig } from '../data/siteConfig';

const featuredServices = services.slice(0, 6);
const fullAddress = `${siteConfig.address.street}, ${siteConfig.address.sector}, ${siteConfig.address.city}, ${siteConfig.address.province}, ${siteConfig.address.country}`;
---

<Layout
  title="Inicio"
  description="Consorcio Jurídico HP — Abogados Asociados. Asesoría y patrocinio legal con seriedad, cercanía y compromiso en Quito, Ecuador."
>
  <section class="relative flex min-h-[80vh] items-center overflow-hidden bg-primary text-white">
    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(0,31,63,0.3),rgba(255,255,255,0.03)_45%,rgba(0,71,140,0.24))]"></div>
    <div class="absolute inset-0 opacity-20 [background-image:radial-gradient(circle_at_top_right,rgba(255,215,0,0.25),transparent_30%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.12),transparent_35%)]"></div>

    <div class="relative mx-auto flex w-full max-w-7xl px-6 py-24 sm:px-8 lg:px-12">
      <div class="max-w-4xl">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-accent sm:text-base">
          Consorcio Jurídico HP — Abogados Asociados
        </p>
        <h1
          class="mt-6 text-4xl leading-tight font-bold font-serif text-white md:text-5xl lg:text-6xl"
        >
          Asesoría y patrocinio legal con seriedad, cercanía y compromiso
        </h1>
        <p class="mt-6 max-w-3xl text-lg text-white/80 md:text-xl">
          Somos un equipo de abogados enfocados en brindar soluciones jurídicas claras, oportunas y
          responsables en distintas materias del Derecho en Quito, Ecuador.
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:flex-wrap">
          <a
            href={siteConfig.whatsappUrl}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center gap-3 rounded-lg bg-[#25D366] px-8 py-3 font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#20BD5A]"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path d="M20 11.5A8.5 8.5 0 0 1 7.4 19l-3.4 1 1.1-3.2A8.5 8.5 0 1 1 20 11.5Z"></path>
              <path d="M9.2 8.8c.2-.5.4-.5.7-.5h.6c.2 0 .5 0 .7.5l.5 1.3c.1.3 0 .6-.2.8l-.5.6c-.2.2-.2.4-.1.6.4.7 1 1.3 1.7 1.8.2.1.5.1.6-.1l.6-.5c.2-.2.5-.3.8-.2l1.3.5c.5.2.5.5.5.7v.6c0 .3 0 .5-.5.7-.5.2-1.6.4-3-.2a9.3 9.3 0 0 1-4.2-4.2c-.6-1.4-.4-2.5-.2-3Z"></path>
            </svg>
            Escríbanos por WhatsApp
          </a>

          <a
            href={`tel:${siteConfig.phoneInternational}`}
            class="inline-flex items-center justify-center gap-3 rounded-lg bg-accent px-8 py-3 font-semibold text-accent-foreground transition-all duration-200 hover:-translate-y-0.5 hover:brightness-105"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path d="M5 4h4l2 5-2.5 1.5a16.3 16.3 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2.2 2A17.8 17.8 0 0 1 3 6.2 2 2 0 0 1 5 4Z"></path>
            </svg>
            Llámenos
          </a>

          <a
            href="/contacto"
            class="inline-flex items-center justify-center gap-3 rounded-lg border-2 border-white px-8 py-3 font-semibold text-white transition-all duration-200 hover:bg-white hover:text-primary"
          >
            Agende su Consulta
          </a>
        </div>
      </div>
    </div>
  </section>

  <section data-reveal class="bg-card py-16">
    <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <div class="text-center p-6 rounded-xl border border-border bg-background">
          <p class="text-4xl md:text-5xl font-bold text-primary dark:text-accent font-serif">13</p>
          <p class="text-muted-foreground text-sm mt-2 uppercase tracking-wider">Áreas de Práctica</p>
        </div>
        <div class="text-center p-6 rounded-xl border border-dashed border-accent/40 bg-accent/5">
          <p class="text-lg font-semibold text-accent font-serif">[POR CONFIRMAR]</p>
          <p class="text-muted-foreground text-sm mt-2 uppercase tracking-wider">Años de Experiencia</p>
          <p class="text-xs text-muted-foreground mt-1 italic">Dato pendiente del abogado</p>
        </div>
        <div class="text-center p-6 rounded-xl border border-dashed border-accent/40 bg-accent/5">
          <p class="text-lg font-semibold text-accent font-serif">[POR CONFIRMAR]</p>
          <p class="text-muted-foreground text-sm mt-2 uppercase tracking-wider">Casos Atendidos</p>
          <p class="text-xs text-muted-foreground mt-1 italic">Dato pendiente del abogado</p>
        </div>
      </div>
    </div>
  </section>

  <section data-reveal class="py-16">
    <div class="mx-auto max-w-3xl px-6 text-center sm:px-8">
      <p class="text-sm font-semibold uppercase tracking-[0.26em] text-accent">Atención jurídica integral</p>
      <h2 class="mt-4 text-3xl font-serif font-bold text-foreground">
        Su aliado legal de confianza en Quito
      </h2>
      <p class="mt-6 text-base leading-8 text-muted-foreground md:text-lg">
        En {siteConfig.shortName} trabajamos con una visión cercana y estratégica para acompañar a
        personas, familias y empresas en decisiones legales que exigen claridad y responsabilidad.
        Combinamos experiencia procesal, asesoría preventiva y seguimiento constante para ofrecer
        respuestas oportunas en cada etapa de su caso.
      </p>
      <a
        href="/nosotros"
        class="mt-8 inline-flex items-center gap-2 font-semibold text-accent transition-transform duration-200 hover:translate-x-1 hover:underline"
      >
        Conozca más sobre nosotros <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <section data-reveal class="bg-card py-16">
    <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.26em] text-accent">Servicios destacados</p>
        <h2 class="mt-4 text-3xl font-serif font-bold text-foreground">Nuestras Áreas de Práctica</h2>
        <p class="mt-4 text-muted-foreground">
          Ofrecemos asesoría legal integral en diversas materias del Derecho
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          featuredServices.map((service) => (
            <div data-reveal>
              <ServiceCard
                title={service.title}
                description={service.shortDescription}
                icon={service.icon}
                slug={service.slug}
              />
            </div>
          ))
        }
      </div>

      <div class="mt-10 text-center">
        <a
          href="/servicios"
          class="inline-flex items-center gap-2 font-semibold text-accent transition-transform duration-200 hover:translate-x-1 hover:underline"
        >
          Ver todos los servicios <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <section data-reveal class="py-16">
    <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.26em] text-accent">Confianza y resultados</p>
        <h2 class="mt-4 text-3xl font-serif font-bold text-foreground">
          Lo que dicen nuestros clientes
        </h2>
      </div>

      <div class="mt-12 mx-auto max-w-2xl rounded-xl border border-dashed border-accent/40 bg-accent/5 p-8 text-center">
        <p class="text-lg font-semibold text-foreground">Sección de testimonios</p>
        <p class="mt-2 text-muted-foreground">
          Aquí se mostrarán testimonios reales de clientes una vez que el abogado los proporcione.
        </p>
        <p class="mt-4 text-xs text-muted-foreground italic">
          Se recomienda incluir 3-4 testimonios con nombre (o iniciales), tipo de caso y una breve opinión del servicio recibido.
        </p>
      </div>
    </div>
  </section>

  <CTABanner />

  <section data-reveal class="bg-card py-16">
    <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.26em] text-accent">Ubicación y contacto</p>
        <h2 class="mt-4 text-3xl font-serif font-bold text-foreground">Encuéntrenos</h2>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,1fr)_1.2fr] lg:items-center">
        <div class="rounded-2xl border border-border bg-background/80 p-8 shadow-sm">
          <h3 class="text-2xl font-serif font-bold text-foreground">Atención en el centro-norte de Quito</h3>
          <p class="mt-4 leading-7 text-muted-foreground">
            Estamos ubicados en una zona estratégica para facilitar reuniones presenciales, revisión de
            documentación y seguimiento oportuno de su caso.
          </p>

          <dl class="mt-8 space-y-5 text-sm sm:text-base">
            <div>
              <dt class="font-semibold uppercase tracking-[0.2em] text-accent">Dirección</dt>
              <dd class="mt-2 leading-7 text-foreground">{fullAddress}</dd>
            </div>
            <div>
              <dt class="font-semibold uppercase tracking-[0.2em] text-accent">Referencia</dt>
              <dd class="mt-2 leading-7 text-foreground">Junto a la Asamblea Nacional del Ecuador</dd>
            </div>
            <div>
              <dt class="font-semibold uppercase tracking-[0.2em] text-accent">Teléfono</dt>
              <dd class="mt-2 text-foreground">
                <a href={`tel:${siteConfig.phoneInternational}`} class="hover:text-accent hover:underline">
                  {siteConfig.phone}
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-semibold uppercase tracking-[0.2em] text-accent">WhatsApp</dt>
              <dd class="mt-2 text-foreground">
                <a
                  href={siteConfig.whatsappUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="hover:text-accent hover:underline"
                >
                  Iniciar conversación
                </a>
              </dd>
            </div>
          </dl>

          <a
            href="/contacto"
            class="mt-8 inline-flex items-center gap-2 font-semibold text-accent transition-transform duration-200 hover:translate-x-1 hover:underline"
          >
            Cómo llegar <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="overflow-hidden rounded-2xl border border-border bg-background shadow-sm" data-reveal>
          <iframe
            src="https://maps.google.com/maps?q=-0.2130,-78.4995&z=15&output=embed"
            width="100%"
            height="300"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Consorcio Jurídico HP en Quito"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>
