---
import CTABanner from '../components/CTABanner.astro';
import { faq } from '../data/faq';
import { siteConfig } from '../data/siteConfig';
import Layout from '../layouts/Layout.astro';

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout
  title="Preguntas Frecuentes"
  description="Respuestas a las preguntas más frecuentes sobre servicios legales en Quito, Ecuador."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)}></script>

  <section class="bg-primary py-20 text-center text-white">
    <div class="mx-auto max-w-4xl px-6">
      <p class="text-sm font-semibold uppercase tracking-[0.32em] text-accent">Guía rápida legal</p>
      <h1 class="mt-4 font-serif text-4xl font-bold md:text-5xl">Preguntas Frecuentes</h1>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-7 text-white/80 md:text-lg">
        Encuentre respuestas a las consultas más comunes sobre nuestros servicios legales
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-3xl px-6">
      <div class="mb-10 text-center" data-reveal>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-accent">Respuestas claras</p>
        <h2 class="mt-4 font-serif text-3xl font-bold text-foreground">Todo lo esencial antes de su consulta</h2>
        <p class="mt-4 text-muted-foreground">
          Revise las inquietudes más habituales sobre costos, tiempos, documentos y alcance del
          acompañamiento jurídico.
        </p>
      </div>

      {faq.map((item, index) => (
        <details
          class="group faq-item mb-4 overflow-hidden rounded-lg border border-border bg-card/70 shadow-sm shadow-black/5 backdrop-blur-sm"
          data-reveal
          style={`transition-delay: ${index * 40}ms;`}
        >
          <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 font-semibold text-foreground transition-colors hover:bg-card/80">
            <span>{item.question}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5 shrink-0 text-accent transition-transform duration-300 group-open:rotate-180"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </summary>
          <div class="faq-answer px-5 pb-5 pt-0 text-muted-foreground leading-relaxed">
            <p class="overflow-hidden border-t border-border/60 pt-4">{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <section class="bg-card py-12 text-center">
    <div class="mx-auto max-w-3xl px-6" data-reveal>
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-accent">Atención personalizada</p>
      <h2 class="mt-4 font-serif text-3xl font-bold text-foreground">¿No encontró su pregunta?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-muted-foreground leading-7">
        No se preocupe, estamos aquí para ayudarle. Contáctenos directamente y resolveremos todas
        sus dudas.
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={siteConfig.whatsappUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex min-w-56 items-center justify-center gap-3 rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-white transition-transform duration-200 hover:-translate-y-0.5 hover:bg-emerald-400"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <path d="M20 11.5A8.5 8.5 0 0 1 7.4 19l-3.4 1 1.1-3.2A8.5 8.5 0 1 1 20 11.5Z"></path>
            <path d="M9.2 8.8c.2-.5.4-.5.7-.5h.6c.2 0 .5 0 .7.5l.5 1.3c.1.3 0 .6-.2.8l-.5.6c-.2.2-.2.4-.1.6.4.7 1 1.3 1.7 1.8.2.1.5.1.6-.1l.6-.5c.2-.2.5-.3.8-.2l1.3.5c.5.2.5.5.5.7v.6c0 .3 0 .5-.5.7-.5.2-1.6.4-3-.2a9.3 9.3 0 0 1-4.2-4.2c-.6-1.4-.4-2.5-.2-3Z"></path>
          </svg>
          Escribir por WhatsApp
        </a>

        <a
          href="/contacto"
          class="inline-flex min-w-56 items-center justify-center gap-3 rounded-full bg-accent px-6 py-3 text-sm font-semibold text-accent-foreground transition-transform duration-200 hover:-translate-y-0.5 hover:brightness-105"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <path d="M4 6h16"></path>
            <path d="M4 12h16"></path>
            <path d="M4 18h10"></path>
          </svg>
          Ir a contacto
        </a>
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>

<style>
  .faq-item summary {
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    padding-top: 0;
    transition:
      max-height 0.35s ease,
      padding-top 0.35s ease;
  }

  .faq-item[open] .faq-answer {
    max-height: 24rem;
    padding-top: 0;
  }
 </style>
