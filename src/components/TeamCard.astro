---
import { url } from '../utils/url';

interface Props {
  name: string;
  title: string;
  specialization: string;
  bio: string;
  imageUrl?: string;
}

const { name, title, specialization, bio, imageUrl }: Props = Astro.props;
---

<article data-reveal class="overflow-hidden rounded-xl border border-border bg-card">
  <div class="flex h-48 items-center justify-center overflow-hidden bg-primary/10">
    {
      imageUrl ? (
        <img src={url(imageUrl)} alt={name} class="h-full w-full object-cover" loading="lazy" />
      ) : (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-24 w-24 text-primary/40"
          aria-hidden="true"
        >
          <circle cx="12" cy="8" r="3.5"></circle>
          <path d="M5 20a7 7 0 0 1 14 0"></path>
          <path d="M3.5 20h17"></path>
        </svg>
      )
    }
  </div>

  <div class="space-y-4 p-6">
    <div>
      <h3 class="font-serif text-xl font-bold text-foreground">{name}</h3>
      <p class="mt-1 text-sm font-semibold text-accent">{title}</p>
    </div>

    <span class="inline-flex rounded-full border border-accent/20 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-primary dark:text-accent">
      {specialization}
    </span>

    <p class="text-sm leading-6 text-muted-foreground line-clamp-4">{bio}</p>
  </div>
</article>
