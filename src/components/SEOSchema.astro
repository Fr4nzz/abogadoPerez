---
import { siteConfig } from '../data/siteConfig';
import { services } from '../data/services';
import { url } from '../utils/url';

const siteOrigin = Astro.site?.href ?? siteConfig.url;
const siteUrl = new URL(import.meta.env.BASE_URL, siteOrigin).href;
const logoUrl = new URL(url('/logo.png'), siteOrigin).href;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: siteConfig.name,
  description: `${siteConfig.tagline} en ${siteConfig.address.city}, ${siteConfig.address.country}.`,
  url: siteUrl,
  telephone: siteConfig.phoneInternational,
  email: siteConfig.email,
  image: logoUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: `${siteConfig.address.building}, ${siteConfig.address.floor}, ${siteConfig.address.office}, ${siteConfig.address.sector}`,
    addressLocality: siteConfig.address.city,
    addressRegion: siteConfig.address.province,
    postalCode: siteConfig.address.postalCode,
    addressCountry: 'EC',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: siteConfig.coordinates.lat,
    longitude: siteConfig.coordinates.lng,
  },
  areaServed: {
    '@type': 'City',
    name: siteConfig.address.city,
  },
  founder: {
    '@type': 'Person',
    name: 'Dr. Héctor Pérez Vilema',
    jobTitle: 'Director Jurídico',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios Legales',
    itemListElement: services.map((service) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: service.title,
      },
    })),
  },
  sameAs: [siteConfig.social.facebook],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
