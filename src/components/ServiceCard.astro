---
interface Props {
  title: string;
  description: string;
  icon: string;
  slug: string;
}

const { title, description, icon, slug }: Props = Astro.props;

const iconMap: Record<string, string> = {
  scale: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M12 3v16"/><path d="M6 7h12"/><path d="M4 7l-2 4a3 3 0 0 0 6 0L6 7Z"/><path d="M20 7l-2 4a3 3 0 0 0 6 0l-2-4Z"/><path d="M8 19h8"/><path d="M7 21h10"/></svg>`,
  family: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M3 11.5 12 4l9 7.5"/><path d="M5 10.5V20h14v-9.5"/><path d="M9.5 20v-4.5a2.5 2.5 0 0 1 5 0V20"/><path d="M8.5 10.5a1.5 1.5 0 1 0 0-.01"/><path d="M15.5 10.5a1.5 1.5 0 1 0 0-.01"/></svg>`,
  briefcase: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="3" y="7" width="18" height="12" rx="2"/><path d="M9 7V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"/><path d="M3 12h18"/><path d="M10 12v2"/><path d="M14 12v2"/></svg>`,
  document: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M8 3h7l4 4v14H8a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z"/><path d="M15 3v5h5"/><path d="M10 12h8"/><path d="M10 16h8"/><path d="M10 8h2"/></svg>`,
  car: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M5 16 6.5 10.5A2 2 0 0 1 8.4 9H15.6a2 2 0 0 1 1.9 1.5L19 16"/><path d="M4 16h16"/><path d="M5 16v3"/><path d="M19 16v3"/><circle cx="7.5" cy="16.5" r="1.5"/><circle cx="16.5" cy="16.5" r="1.5"/><path d="M8 9 9.5 6h5L16 9"/></svg>`,
  building: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="4" y="3" width="12" height="18" rx="1.5"/><path d="M16 8h4v13h-4"/><path d="M8 7h2"/><path d="M8 11h2"/><path d="M8 15h2"/><path d="M12 7h2"/><path d="M12 11h2"/><path d="M12 15h2"/><path d="M9 21v-3h2v3"/></svg>`,
  corporate: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="3" y="9" width="6" height="10" rx="1"/><rect x="9" y="5" width="6" height="14" rx="1"/><rect x="15" y="2" width="6" height="17" rx="1"/><path d="M5 12h2"/><path d="M5 15h2"/><path d="M11 8h2"/><path d="M11 11h2"/><path d="M11 14h2"/><path d="M17 6h2"/><path d="M17 9h2"/><path d="M17 12h2"/></svg>`,
  contract: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M7 3h8l4 4v12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z"/><path d="M15 3v5h5"/><path d="M8.5 12h7"/><path d="M8.5 15.5h4.5"/><path d="M8.5 9h3"/><path d="M15.5 14.5l1.5 1.5 3-3"/></svg>`,
  money: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="3" y="6" width="18" height="12" rx="2"/><circle cx="12" cy="12" r="3"/><path d="M7 9.5h.01"/><path d="M17 14.5h.01"/><path d="M12 9v6"/><path d="M10.5 10.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5-1.5.67-1.5 1.5.67 1.5 1.5 1.5 1.5-.67 1.5-1.5"/></svg>`,
  home: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M3 11.5 12 4l9 7.5"/><path d="M5 10.5V20h14v-9.5"/><path d="M9 20v-5h6v5"/></svg>`,
  stamp: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M9 13a3 3 0 1 1 6 0c0 1 .35 1.82 1 2.5l1 1V18H7v-1.5l1-1c.65-.68 1-1.5 1-2.5Z"/><path d="M6 21h12"/><path d="M8 18h8"/><path d="M10 6V4h4v2"/></svg>`,
  chart: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M4 20h16"/><path d="M7 20v-6"/><path d="M12 20v-10"/><path d="M17 20v-13"/><path d="M6 8.5 10 5l4 3 4-5"/></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M12 3 5 6v5c0 4.4 2.9 8.5 7 10 4.1-1.5 7-5.6 7-10V6l-7-3Z"/><path d="m9.5 12 1.8 1.8 3.2-3.6"/></svg>`,
};

const iconMarkup = iconMap[icon] ?? iconMap.shield;
---

<article
  data-reveal
  data-slug={slug}
  class="bg-card rounded-xl border border-border p-6 transition-all hover:-translate-y-1 hover:shadow-lg"
>
  <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 text-accent">
    <Fragment set:html={iconMarkup} />
  </div>

  <h3 class="font-serif text-xl font-bold text-foreground">{title}</h3>
  <p class="mt-3 text-sm leading-6 text-muted-foreground line-clamp-3">{description}</p>

  <a
    href={`/servicios/${slug}`}
    class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-accent transition-transform duration-200 hover:translate-x-1"
  >
    Más información <span aria-hidden="true">→</span>
  </a>
</article>
