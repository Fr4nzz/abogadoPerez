---
import { siteConfig } from '../data/siteConfig';

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = '¿Necesita asesoría legal?',
  text = 'Contáctenos hoy para una consulta. Nuestro equipo de abogados está listo para ayudarle.',
}: Props = Astro.props;
---

<section data-reveal class="bg-primary py-16 text-center text-primary-foreground">
  <div class="mx-auto max-w-4xl px-6">
    <p class="text-sm font-semibold uppercase tracking-[0.32em] text-accent">Atención inmediata</p>
    <h2 class="mt-4 font-serif text-3xl font-bold md:text-4xl">{heading}</h2>
    <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-primary-foreground/80">
      {text}
    </p>

    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={siteConfig.whatsappUrl}
        target="_blank"
        rel="noreferrer"
        class="inline-flex min-w-56 items-center justify-center gap-3 rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-white transition-transform duration-200 hover:-translate-y-0.5 hover:bg-emerald-400"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-5 w-5"
          aria-hidden="true"
        >
          <path d="M20 11.5A8.5 8.5 0 0 1 7.4 19l-3.4 1 1.1-3.2A8.5 8.5 0 1 1 20 11.5Z"></path>
          <path d="M9.2 8.8c.2-.5.4-.5.7-.5h.6c.2 0 .5 0 .7.5l.5 1.3c.1.3 0 .6-.2.8l-.5.6c-.2.2-.2.4-.1.6.4.7 1 1.3 1.7 1.8.2.1.5.1.6-.1l.6-.5c.2-.2.5-.3.8-.2l1.3.5c.5.2.5.5.5.7v.6c0 .3 0 .5-.5.7-.5.2-1.6.4-3-.2a9.3 9.3 0 0 1-4.2-4.2c-.6-1.4-.4-2.5-.2-3Z"></path>
        </svg>
        Escribir por WhatsApp
      </a>

      <a
        href={`tel:${siteConfig.phoneInternational}`}
        class="inline-flex min-w-56 items-center justify-center gap-3 rounded-full bg-accent px-6 py-3 text-sm font-semibold text-accent-foreground transition-transform duration-200 hover:-translate-y-0.5 hover:brightness-105"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-5 w-5"
          aria-hidden="true"
        >
          <path d="M5 4h4l2 5-2.5 1.5a16.3 16.3 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2.2 2A17.8 17.8 0 0 1 3 6.2 2 2 0 0 1 5 4Z"></path>
        </svg>
        Llamar ahora
      </a>
    </div>
  </div>
</section>
